int jump(int* nums, int numsSize) {
    
    int jump = 0;
    int end = 0;
    int far = 0;

    for (int i = 0; i < numsSize - 1; i++)
    {
        if ( i + nums[i] > far)
        {
            far = i + nums[i];
        }
        if (i == end)
        {
            jump++;
            end = far;
        }
}
    return jump;
}
