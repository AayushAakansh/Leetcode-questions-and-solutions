int minAbsoluteDifference(int* nums, int numsSize) {
    
    int found=0;
    int minResult = 9999;
    for(int i=0; i<numsSize; i++)
    {
        for(int j = 0; j<numsSize; j++)
        {
            if(nums[i] == 1 && nums[j] == 2)
            {
                int result = abs(i-j);
                if(result < minResult)
                {
                    minResult = result;
                }
                found=1;
            }
            
        }
    }
    if (found==0)
    {
        return -1;
    }
    else
    {
        return minResult;;
    }
}
