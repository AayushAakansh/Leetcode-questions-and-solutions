int findSpecialInteger(int* arr, int arrSize) {
    
    int counting = 0.25 * arrSize;
    int digit = 0;
    int count=1;
    for(int i=1; i< arrSize; i++)
    {
        if (arr[i] == arr[i-1])
        {
            count++;
        }
        else
        {
            count=1;
        }
        if (count > counting)
        {
            digit = arr[i];
            return digit;
        }
    }
    return arr[0];
}
