int firstUniqueEven(int* nums, int numsSize) {
    
    for(int i=0; i<numsSize; i++)
    {
        if(nums[i] % 2 ==0)
        {
            int count=0;
            for(int j=0; j<numsSize; j++)
            {
                if(nums[j] == nums[i])
                {
                    count++;
                }
            }
            if(count==1)
            {
                return nums[i];
            }
        }
    }
    return -1;
}
