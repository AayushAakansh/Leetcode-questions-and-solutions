int findMiddleIndex(int* nums, int numsSize) {
    
    int total = 0;
    for(int i = 0; i<numsSize; i++)
    {
        total = total + nums[i];
    }
    for(int i = 0; i< numsSize; i++)
    {
        int pivot = i;
        int left = 0;
        for(int j = 0; j <i; j++)
        {
            left = left + nums[j];
        }
        int right = total - left - nums[i];
        if (left == right)
        {
            return pivot;
        }
    }
    return -1;
}
