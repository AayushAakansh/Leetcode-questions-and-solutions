bool isPalindrome(int x)
{
    int copy = x;
    int rev=0;
    while (x!=0)
    {
        int temp = x%10;
        rev = rev*10 + temp;
        x = x/10;
    }
    if (copy == rev)
    {
        return true;
    }
    return false;
}

bool isPrime(int x)
{
    if(x<2)
    {
        return false;
    }
    for (int i =2; i*i <= x; i++)
    {
        if (x % i ==0)
        {
            return false;
        }
    }
    return true;
}
int primePalindrome(int n) {
    
    while(true)
    {
        if (n>11 && n % 2 == 0)
        {
            n++;
            continue;
        }
        if(isPalindrome(n) && isPrime(n))
        {
            return n;
        }
        n++;
    }

}
