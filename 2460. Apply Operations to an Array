/**
 * Note: The returned array must be malloced, assume caller calls free().
 */
 void shiftZeros(int* nums, int numsSize)
 {
    int curr = 0;
    for(int i = 0; i< numsSize; i++)
    {
        if(nums[i] != 0)
        {
            nums[curr++] = nums[i];
        }
    }
    while (curr < numsSize)
    {
        nums[curr++] = 0;
    }
 }

int* applyOperations(int* nums, int numsSize, int* returnSize) {
    
    *returnSize = numsSize;
    for(int i = 0; i< numsSize-1; i++)
    {
        if (nums[i] == nums[i+1])
        {
            nums[i] = nums[i] *2;
            nums[i+1] = 0;
        }
    }
    shiftZeros(nums, numsSize);
    int* result = (int* )malloc(*returnSize * sizeof(int));
    for(int i = 0; i< numsSize; i++)
    {
        result[i] = nums[i];
    }
    return result;
}
