long long sumAndMultiply(int n) {
    
    if (n == 0)
    {
        return 0;
    }
    int digits[20];
    int count = 0;
    while (n > 0)
    {
        digits[count++] = n % 10;
        n = n/10;
    }
    long long x = 0;
    int sum = 0;
    for(int i = count-i; i >= 0; i--)
    {
        if(digits[i] != 0)
        {
            x = x*10 + digits[i];
            sum+= digits[i];
        }
    }
    return x*sum;
}
