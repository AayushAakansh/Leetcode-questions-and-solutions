int mySqrt(int x) {
    
    long long int temp;
    int sq=0;
    if (x==0)
    {
        return 0;
    }
    if (x==1)
    {
        return 1;
    }
    for (int i=0; i<=x;i++)
    {
        temp=(long long) i*i;
        if (temp<=x)
        {
            sq=i;
        }
        else
        {
            break;
        }

    }
    return sq;
}
