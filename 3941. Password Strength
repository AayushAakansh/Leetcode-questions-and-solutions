int passwordStrength(char* password) {
    
    int seen[128] = {0};
    int point = 0;
    int l = strlen(password);
    for(int i= 0; i < l; i++)
    {
        char temp = password[i];
        if (seen[(int)temp])
        {
            continue;
        }
        seen[(int)temp]=  1;

        if (temp <='z' && temp >='a')
        {
            point = point + 1;
        }
        else if (temp <= 'Z' && temp >= 'A')
        {
            point = point +2;
        }
        else if (temp >= '0' && temp <= '9')
        {
            point = point + 3;
        }
        else
        {
            point = point + 5;
        }
    }
    return point;
}
