int reverse(int n)
{
    int rev = 0;
    while (n != 0)
    {
        int temp = n % 10;
        rev = rev * 10 + temp;
        n=  n/10;
    }
    return rev;
}
bool isPrime(int n)
{
    if (n<=1)
    {
        return false;
    }
    for(int i = 2; i*i <= n; i++)
    {
        if (n % i == 0)
        {
            return false;
        }
    }
    return true;
}

int sumOfPrimesInRange(int n) {
    
    int rev = reverse(n);
    int sum = 0;
    int start = 0;
    int end = 0;
    if (n < rev)
    {
        start = n;
        end = rev;
    }
    else
    {
        start = rev;
        end = n;
    }

    for (int i = start; i <= end; i++)
    {
        if(isPrime(i))
        {
            sum = sum +i;
        }
    }
    return sum;
}
