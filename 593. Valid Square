int dist(int* a, int* b)
{
    int x = a[0] - b[0];
    int y = a[1] - b[1];
    return x*x + y*y;
}
bool validSquare(int* p1, int p1Size, int* p2, int p2Size, int* p3, int p3Size, int* p4, int p4Size) {
    
    int d[6];
    d[0] = dist(p1,p2);
    d[1] = dist(p1,p3);
    d[2] = dist(p1,p4);
    d[3] = dist(p2,p3);
    d[4] = dist(p2,p4);
    d[5] = dist(p3,p4);
    for (int i=0; i<6; i++)
    {
        for (int j=i+1; j<6; j++)
        {
            if(d[i] > d[j])
            {
                int temp = d[i];
                d[i] = d[j];
                d[j] = temp;
            }
        }
    }

    if (d[0] > 0 && d[0] == d[1] && d[1] == d[2] && d[2] == d[3] && d[4] == d[5])
    {
        return true;
    }
    return false;

   
}
