int minimumSwaps(int* nums, int numsSize) {
    
    int count=0;
    int left = 0;
    int right = numsSize -1;
    while (left < right)
    {
        while(left < right && nums[left] != 0)
        {
            left++;
        }
        while(left < right && nums[right] == 0)
        {
            right--;
        }
        if (left < right)
        {
            int temp = nums[left];
            nums[left] = nums[right];
            nums[right] = temp;
            count++;
        }
    }
    return count;

}
