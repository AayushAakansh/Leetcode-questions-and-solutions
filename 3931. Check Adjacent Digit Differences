bool isAdjacentDiffAtMostTwo(char* s) {
    
    int l = strlen(s);
    for(int i = 0; i < l-1; i++)
    {
        int d1 = s[i] - '0';
        int d2 = s[i+1] - '0';

        int diff = d1-d2;
        if (diff < 0)
        {
            diff = -diff;
        }
        if (diff > 2)
        {
            return false;
        }
    }
    return true;
}
