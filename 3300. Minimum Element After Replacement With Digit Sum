int minElement(int* nums, int numsSize) {
    
    for(int i=0; i<numsSize; i++)
    {
        int sum=0;
        while(nums[i] != 0)
        {
            int temp = nums[i] % 10;
            sum = sum + temp;
            nums[i] = nums[i] / 10;
        }
        nums[i] = sum;
    }
    int minimum = nums[0];
    for(int i=0; i<numsSize; i++)
    {
        if(nums[i]<minimum)
        {
            minimum = nums[i];
        }
    }
    return minimum;
}
