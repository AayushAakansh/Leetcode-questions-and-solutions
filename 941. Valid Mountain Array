bool validMountainArray(int* arr, int arrSize){

    if(arrSize < 3)
    {
        return false;
    }

    int max = arr[0];
    int maxIdx = 0;
    for(int i=0; i<arrSize; i++)
    {
        if(arr[i]>max)
        {
            max = arr[i];
            maxIdx = i;
        }
    }
    if(maxIdx == 0 || maxIdx == arrSize-1)
    {
        return false;
    }

    for(int i=0; i<maxIdx; i++)
    {
        if(arr[i] >=arr[i+1])
        {
            return false;
        }
    }
    for(int i=maxIdx; i<arrSize-1; i++)
    {
        if(arr[i] <= arr[i+1])
        {
            return false;
        }
    }
    return true;

}
