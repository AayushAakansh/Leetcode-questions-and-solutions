int differenceOfSum(int* nums, int numsSize) {
    
    int element = 0;
    for(int i=0; i<numsSize; i++)
    {
        element = element + nums[i];
    }
    int digit = 0;
    for(int i=0; i<numsSize; i++)
    {
        if(nums[i]<10)
        {
            digit = digit+nums[i];
        }
        else
        {
            while(nums[i] != 0)
            {
                int temp = nums[i] % 10;
                digit = digit + temp;
                nums[i] = nums[i] /10;
            }
        }
    }
    return abs(element - digit);
}
