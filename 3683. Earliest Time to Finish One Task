int earliestTime(int** tasks, int tasksSize, int* tasksColSize) {
    
    int min = tasks[0][0] + tasks[0][1];
    for(int i=0; i<tasksSize; i++)
    {
        int sum=0;
        for(int j=0; j< *tasksColSize; j++)
        {
            sum =sum+tasks[i][j];
        }
        if (sum < min)
        {
            min = sum;
        }
    }
    return min;
}
